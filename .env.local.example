# Supabase (public — exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase service-role (server only — bypasses RLS, never expose)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# INSEE Sirene API (server only)
# Since 2024, INSEE moved to portal.insee.fr API keys.
# Set INSEE_API_KEY for the new auth scheme (header X-INSEE-Api-Key-Integration).
# If you still use the legacy OAuth2 client_credentials flow, set the *_OAUTH_* vars instead.
INSEE_API_KEY=
INSEE_OAUTH_CONSUMER_KEY=
INSEE_OAUTH_CONSUMER_SECRET=
INSEE_BASE_URL=https://api.insee.fr/api-sirene/3.11
INSEE_OAUTH_TOKEN_URL=https://api.insee.fr/token

# INPI RNE — server only
# Account at procedures.inpi.fr, API access requested on data.inpi.fr → "Mes accès API/SFTP".
INPI_USERNAME=
INPI_PASSWORD=
INPI_BASE_URL=https://registre-national-entreprises.inpi.fr/api
